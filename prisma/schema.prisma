// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ============================================
// المستخدمين
// ============================================
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String         // hashed password
  name          String?
  phone         String?
  avatar        String?
  level         String         @default("مبتدئ")
  points        Int            @default(0)
  role          String         @default("user") // user, admin
  emailVerified DateTime?
  isActive      Boolean        @default(true)
  stripeCustomerId String?
  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  userCertificates UserCertificate[]
  payments         Payment[]
  examAttempts     ExamAttempt[]
  notifications    Notification[]
  adminLogs        AdminLog[]
  userBadges       UserBadge[]
}

// ============================================
// الشهادات
// ============================================
model Certificate {
  id              String   @id @default(cuid())
  title           String
  titleEn         String   @map("title_en")
  description     String
  category        String
  price           Float
  originalPrice   Float    @map("original_price")
  duration        String
  level           String   // مبتدئ, متوسط, متقدم, خبير
  skills          String   // JSON array
  passingScore    Int      @default(70) @map("passing_score")
  totalQuestions  Int      @map("total_questions")
  examDuration    Int      @map("exam_duration") // بالدقائق
  featured        Boolean  @default(false)
  image           String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  userCertificates UserCertificate[]
  examAttempts     ExamAttempt[]

  @@map("certificates")
}

// ============================================
// شهادات المستخدمين
// ============================================
model UserCertificate {
  id              String     @id @default(cuid())
  certificateId   String     @map("certificate_id")
  userId          String     @map("user_id")
  certificateNumber String   @unique @map("certificate_number")
  score           Int
  status          String     @default("valid") // valid, expired, revoked
  issueDate       DateTime   @default(now()) @map("issue_date")
  expiryDate      DateTime?  @map("expiry_date")
  
  certificate     Certificate @relation(fields: [certificateId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
  paymentId       String?     @unique @map("payment_id")
  payment         Payment?    @relation(fields: [paymentId], references: [id])
  
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("user_certificates")
}

// ============================================
// المدفوعات
// ============================================
model Payment {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  certificateId   String?  @map("certificate_id")
  amount          Float
  currency        String   @default("USD")
  status          String   @default("pending") // pending, completed, failed, refunded
  paymentMethod   String   @map("payment_method") // stripe, paypal
  stripePaymentId String?  @map("stripe_payment_id")
  stripeSessionId String?  @map("stripe_session_id")
  paypalOrderId   String?  @map("paypal_order_id")
  metadata        String?  // JSON for additional data
  
  user            User     @relation(fields: [userId], references: [id])
  userCertificate UserCertificate?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

// ============================================
// محاولات الاختبارات
// ============================================
model ExamAttempt {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  certificateId   String   @map("certificate_id")
  answers         String   // JSON array of answers
  score           Int
  passed          Boolean
  startedAt       DateTime @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  timeSpent       Int?     @map("time_spent") // بالثواني
  
  user            User        @relation(fields: [userId], references: [id])
  certificate     Certificate @relation(fields: [certificateId], references: [id])
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("exam_attempts")
}

// ============================================
// الأسئلة
// ============================================
model Question {
  id              String   @id @default(cuid())
  certificateId   String   @map("certificate_id")
  question        String
  options         String   // JSON array
  correctAnswer   Int      @map("correct_answer") // index of correct option
  explanation     String?
  order           Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("questions")
}

// ============================================
// كوبونات الخصم
// ============================================
model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int?     @map("discount_percent")
  discountAmount  Float?   @map("discount_amount")
  maxUses         Int?     @map("max_uses")
  currentUses     Int      @default(0) @map("current_uses")
  validFrom       DateTime @default(now()) @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  isActive        Boolean  @default(true) @map("is_active")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("coupons")
}

// ============================================
// إعدادات المنصة
// ============================================
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ============================================
// الإشعارات
// ============================================
model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  message     String
  type        String   // certificate, payment, system, reminder, achievement
  link        String?  // رابط للانتقال عند النقر
  data        String?  // JSON for additional data
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

// ============================================
// سجل المشرف
// ============================================
model AdminLog {
  id          String   @id @default(cuid())
  adminId     String   @map("admin_id")
  action      String   // create, update, delete, login
  model       String   // User, Certificate, Payment
  recordId    String?  @map("record_id")
  oldData     String?  @map("old_data") // JSON
  newData     String?  @map("new_data") // JSON
  ip          String?
  userAgent   String?  @map("user_agent")
  
  admin       User     @relation(fields: [adminId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("admin_logs")
}

// ============================================
// البادج (الشارات)
// ============================================
model Badge {
  id              String   @id @default(cuid())
  name            String
  nameEn          String   @map("name_en")
  description     String
  descriptionEn   String   @map("description_en")
  icon            String   // اسم الأيقونة
  color           String   @default("#FFD700") // لون البادج
  type            String   // first_certificate, certificates_5, certificates_10, all_levels, perfect_score, speed_achievement
  requirement     String   // JSON يحتوي على متطلبات الحصول على البادج
  points          Int      @default(0) // النقاط الممنوحة عند الحصول على البادج
  isActive        Boolean  @default(true) @map("is_active")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  userBadges      UserBadge[]
  
  @@map("badges")
}

// ============================================
// بادج المستخدمين
// ============================================
model UserBadge {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  badgeId     String   @map("badge_id")
  earnedAt    DateTime @default(now()) @map("earned_at")
  
  user        User     @relation(fields: [userId], references: [id])
  badge       Badge    @relation(fields: [badgeId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ============================================
// رسائل التواصل
// ============================================
model ContactMessage {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String?
  subject       String
  message       String
  category      String    @default("general") // general, support, partnership, feedback, other
  status        String    @default("new") // new, read, replied, archived
  adminNotes    String?   @map("admin_notes")
  readAt        DateTime? @map("read_at")
  repliedAt     DateTime? @map("replied_at")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("contact_messages")
}
